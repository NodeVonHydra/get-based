  "notes": [
    {
      "date": "2025-04-10",
      "text": "Baseline panel. Blood draw on day 7 of cycle (early follicular). Ferritin already borderline low — doctor recommended iron supplementation. Feeling fatigued, especially around periods."
    },
    {
      "date": "2025-08-05",
      "text": "Mid-luteal draw (day 22). Progesterone elevated as expected for this phase. Ferritin dropped further despite 25mg iron. Switching to iron bisglycinate 36mg with vitamin C. TSH creeping up — monitoring."
    },
    {
      "date": "2025-12-15",
      "text": "Early follicular draw (day 5). Hemoglobin lowest yet — almost at lower reference limit. Iron saturation below range. Increased iron dose. TSH continues rising, fT4 dropping. GP ordered thyroid antibodies for next visit."
    },
    {
      "date": "2026-01-25",
      "text": "Day 10 (late follicular). Iron and hemoglobin finally improving! Two months of consistent high-dose iron bisglycinate working. But TSH still climbing — fT4 now near lower boundary. Endocrinology referral pending."
    }
  ],
